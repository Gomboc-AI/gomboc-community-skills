  "capabilities": {
    "scan": {
      "description": "Scan infrastructure code for security issues",
      "commands": [
        "@gomboc scan path:./terraform",
        "@gomboc scan path:./infrastructure policy:aws-cis format:markdown"
      ]
    },
    "fix": {
      "description": "Generate deterministic security fixes",
      "commands": [
        "@gomboc fix path:./terraform",
        "@gomboc fix path:./infrastructure format:pull_request"
      ]
    },
    "remediate": {
      "description": "Apply fixes directly to code",
      "commands": [
        "@gomboc remediate path:./terraform commit:true"
      ]
    }
  },
  "requirements": {
    "claudeVersion": "1.0+",
    "runtimeDependencies": [
      "python3.7+"
    ],
    "externalServices": [
      {
        "name": "Gomboc API",
