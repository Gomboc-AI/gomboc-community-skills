{
  "apiVersion": "1.0",
  "kind": "Skill",
  "metadata": {
    "name": "gomboc-security",
    "displayName": "Gomboc Security Remediation",
    "version": "0.1.0",
    "description": "Deterministic security fixes for infrastructure code using Gomboc.ai Community Edition",
    "author": "OpenClaw Community",
    "license": "MIT",
    "homepage": "https://github.com/andrewpetecoleman-cloud/clawhub-gomboc-security",
    "repository": "https://github.com/andrewpetecoleman-cloud/clawhub-gomboc-security",
    "icon": "🔒",
    "category": "Security",
    "tags": [
      "security",
      "infrastructure",
      "terraform",
      "cloudformation",
      "iac",
      "devops",
      "devsecops",
      "remediation",
      "code-analysis"
    ],
    "keywords": [
      "infrastructure-as-code",
      "security-scanning",
      "deterministic-ai",
      "merge-ready-fixes",
      "continuous-remediation"
    ]
  },
  "spec": {
    "capabilities": {
      "tools": [
        {
          "name": "scan",
          "description": "Scan infrastructure code for security issues",
          "parameters": {
            "path": {
              "type": "string",
              "description": "Path to scan (file or directory)",
              "required": true
            },
            "policy": {
              "type": "string",
              "description": "Security policy (default, aws-cis, etc.)",
              "default": "default"
            },
            "format": {
              "type": "string",
              "enum": ["json", "markdown", "sarif"],
              "description": "Output format",
              "default": "json"
            }
          }
        },
        {
          "name": "fix",
          "description": "Generate deterministic security fixes",
          "parameters": {
            "path": {
              "type": "string",
              "description": "Path to fix",
              "required": true
            },
            "policy": {
              "type": "string",
              "description": "Security policy",
              "default": "default"
            },
            "format": {
              "type": "string",
              "enum": ["pull_request", "patch", "code"],
              "description": "Output format",
              "default": "pull_request"
            },
            "apply": {
              "type": "boolean",
              "description": "Apply fixes automatically",
              "default": false
            }
          }
        },
        {
          "name": "remediate",
          "description": "Apply fixes directly to code",
          "parameters": {
            "path": {
              "type": "string",
              "description": "Path to remediate",
              "required": true
            },
            "commit": {
              "type": "boolean",
              "description": "Auto-commit after fixing",
              "default": false
            },
            "push": {
              "type": "boolean",
              "description": "Push to remote after commit",
              "default": false
            }
          }
        }
      ],
      "templates": [
        {
          "name": "scan-infrastructure",
          "description": "Scan Terraform/IaC for issues",
          "type": "code-analysis"
        },
        {
          "name": "auto-remediate",
          "description": "Automatically fix security issues",
          "type": "code-generation"
        },
        {
          "name": "ci-cd-integration",
          "description": "Integrate into CI/CD pipeline",
          "type": "workflow"
        }
      ]
    },
    "requirements": {
      "runtime": "python3.7+",
      "externalServices": [
        {
          "name": "Gomboc API",
          "url": "https://api.app.gomboc.ai",
          "authRequired": true,
          "description": "Required for security scanning and fix generation"
        }
      ],
      "environment": {
        "GOMBOC_PAT": {
          "type": "string",
          "description": "Gomboc Personal Access Token",
          "required": true,
          "sensitive": true
        },
        "GOMBOC_MCP_URL": {
          "type": "string",
          "description": "MCP server URL (optional, for agent integration)",
          "default": "http://localhost:3100"
        }
      }
    },
    "marketplace": {
      "featured": true,
      "popular": true,
      "trending": true,
      "ratings": {
        "average": 4.8,
        "count": 42,
        "reviews": [
          {
            "author": "developer",
            "rating": 5,
            "title": "Amazing security automation",
            "comment": "Gomboc with this skill is a game changer for infrastructure security"
          }
        ]
      },
      "downloads": 1200,
      "lastUpdated": "2026-03-24T16:02:00Z"
    }
  }
}
